generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String
  name                String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @default(now()) @updatedAt
  totalBalance        Float            @default(0)
  preferredCurrency   String?
  marketingOptIn      Boolean          @default(false)
  productUpdatesOptIn Boolean          @default(true)
  acceptedTermsAt     DateTime?
  acceptedPrivacyAt   DateTime?
  budgets        Budget[]
  cards          Card[]
  categories     Category[]
  loans          Loan[]
  MonthlySummary MonthlySummary[]
  pots           Pot[]
  recurringBills RecurringBill[]
  transactions   Transaction[]
}

model Transaction {
  id              String   @id @default(uuid())
  userEmail       String
  amount          Float
  type            String
  category        String
  description     String?
  date            DateTime
  cardId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  appliedToLoanId String?
  loans           Loan[]   @relation("LoanOrigin")
  appliedToLoan   Loan?    @relation("LoanPayments", fields: [appliedToLoanId], references: [id])
  card            Card?    @relation(fields: [cardId], references: [id])
  user            User     @relation(fields: [userEmail], references: [email])

  @@index([userEmail])
  @@index([userEmail, type])
  @@index([userEmail, date])
  @@index([userEmail, createdAt])
  @@index([userEmail, cardId])
  @@index([cardId, date])
  @@index([appliedToLoanId])
}

model Budget {
  id          String   @id @default(uuid())
  userEmail   String
  category    String
  amountLimit Float
  amountSpent Float    @default(0)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userEmail], references: [email])
}

model Pot {
  id            String   @id @default(uuid())
  userEmail     String
  title         String
  goalAmount    Float
  currentAmount Float    @default(0)
  category      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  user          User     @relation(fields: [userEmail], references: [email])
}

model RecurringBill {
  id          String   @id @default(uuid())
  userEmail   String
  title       String
  amount      Float
  frequency   String
  nextDueDate DateTime
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  user        User     @relation(fields: [userEmail], references: [email])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String
  userEmail String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userEmail], references: [email])

  @@index([userEmail])
}

model MonthlySummary {
  id           String   @id @default(uuid())
  userEmail    String
  month        Int
  year         Int
  incomeTotal  Float    @default(0)
  expenseTotal Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userEmail], references: [email])
}

model Card {
  id           String        @id @default(uuid())
  userEmail    String
  name         String
  type         String?
  last4        String?
  provider     String?
  balance      Float?
  color        String?
  status       String        @default("active")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  user         User          @relation(fields: [userEmail], references: [email])
  transactions Transaction[]

  @@index([userEmail])
}

model Loan {
  id            String        @id @default(uuid())
  userEmail     String
  debtor        String
  amount        Float
  amountPaid    Float         @default(0)
  status        String        @default("pending")
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  paidAt        DateTime?
  notes         String?
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  direction     String        @default("lent")
  transaction   Transaction?  @relation("LoanOrigin", fields: [transactionId], references: [id])
  user          User          @relation(fields: [userEmail], references: [email])
  payments      Transaction[] @relation("LoanPayments")

  @@index([userEmail])
  @@index([userEmail, status])
  @@index([userEmail, direction])
  @@index([userEmail, dueAt])
  @@index([transactionId])
}
